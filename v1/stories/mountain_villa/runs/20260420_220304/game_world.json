  "clues": [
    {
      "id": "C1",
      "content": "书房里发现了一本关于罕见毒药的医学专著，书页上有李华的指纹。",
      "clue_type": "key_clue",
      "deduction_link": {
        "truth_dimension": "凶手",
        "target_value": "李华",
        "reasoning": "只有医生李华才可能拥有并研究这类罕见的毒药，书上的指纹直接指向他。"
      },
      "unlock_condition": null
    },
    {
      "id": "C2",
      "content": "在书房的保险箱里发现了一封李云峰写给李华的信，信中承认当年为了财产而故意延误了李华母亲的病情，导致其死亡。",
      "clue_type": "key_clue",
      "deduction_link": {
        "truth_dimension": "动机",
        "target_value": "复仇",
        "reasoning": "这封信揭示了李云峰的罪行，解释了李华的杀人动机是复仇。"
      },
      "unlock_condition": null
    },
    {
      "id": "C3",
      "content": "法医初步鉴定报告显示，死者体内含有一种罕见的慢性神经毒素，与书房里那本专著中描述的毒药成分一致。同时，死者卧室的茶杯里有微量的毒药残留。",
      "clue_type": "key_clue",
      "deduction_link": {
        "truth_dimension": "手法",
        "target_value": "毒药",
        "reasoning": "法医报告和茶杯中的毒药残留共同证明了死因是中毒，而非表面上的重击。"
      },
      "unlock_condition": null
    },
    {
      "id": "C4",
      "content": "李明提到他父亲有个习惯，用母亲的生日作为重要文件的密码。",
      "clue_type": "pre_clue",
      "deduction_link": null,
      "unlock_condition": null
    },
    {
      "id": "C5",
      "content": "李芳说她在书房看到李华在翻阅一本厚厚的医学书。",
      "clue_type": "pre_clue",
      "deduction_link": null,
      "unlock_condition": null
    },
    {
      "id": "C6",
      "content": "破碎的花瓶是李云峰从欧洲带回来的古董，价值连城。",
      "clue_type": "filler_clue",
      "deduction_link": null,
